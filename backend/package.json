{
  "name": "pb-backend",
  "version": "1.0.0",
  "description": "Backend for personal CRM & Address Book",
  "main": "server.js",
  "bin": "server.js",
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^5.2.1",
