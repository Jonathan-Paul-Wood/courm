{
  "name": "courm",
  "version": "0.1.0",
  "description": "Personal CRM / Address Book",
  "author": "Jonathan Paul Wood",
  "private": true,
  "scripts": {
    "prestart": "node scripts/patch-react-scripts.js",
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "test-coverage": "react-scripts test --collect-coverage",
    "lint": "eslint ./src",
    "lint-fix": "eslint ./src --fix",
    "lint-fix-dry-run": "eslint ./src --fix-dry-run",
    "eject": "react-scripts eject",
    "postinstall": "node scripts/patch-react-scripts.js"
  },
  "dependencies": {
    "@popperjs/core": "^2.11.8",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "axios": "^1.13.6",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "classnames": "^2.5.1",
    "history": "5.3.0",
    "js-cookie": "^3.0.5",
    "prop-types": "^15.8.1",
    "qs": "^6.15.0",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.10",
    "react-datepicker": "^4.25.0",
    "react-dom": "^18.3.1",
    "react-popper": "^2.3.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.13.1",
    "react-scripts": "^5.0.1",
    "react-select": "^5.10.2",
    "react-toastify": "^11.0.5",
    "redux": "^5.0.1",
    "redux-logger": "^3.0.6",
    "redux-thunk": "^3.1.0",
    "sass": "^1.93.2",
    "styled-components": "^6.1.19"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "husky": {
    "hooks": {
      "pre-push": "npm run test && npm run lint"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/plugin-proposal-export-default-from": "^7.27.1",
    "eslint": "^8.57.1",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-react": "^7.37.5",
    "typescript": "^4.9.5"
  }
}
