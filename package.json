{
  "name": "courm-desktop",
  "version": "0.1.0",
  "description": "Desktop packaging and launcher for CouRM",
  "author": "Jonathan Paul Wood",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "clean:dist": "node -e \"require('fs').rmSync('dist-desktop', { recursive: true, force: true })\"",
    "build:ui": "npm --prefix ui run build",
    "desktop": "npm run build:ui && electron .",
    "dist": "npm run dist:win",
    "dist:win": "npm run clean:dist && npm run build:ui && electron-builder --win nsis",
    "dist:mac": "npm run clean:dist && npm run build:ui && electron-builder --mac dmg",
    "dist:linux": "npm run clean:dist && npm run build:ui && electron-builder --linux AppImage",
    "dist:dir": "npm run build:ui && electron-builder --dir",
    "release": "npm run build:ui && electron-builder --publish never"
  },
  "dependencies": {
    "body-parser": "^1.20.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jonathanpaulwood.courm",
    "productName": "CouRM",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "desktop/**/*",
      "backend/**/*",
      "ui/build/**/*",
      "package.json",
      "!backend/node_modules/**/*",
      "!backend/storage/**/*",
      "!backend/main.db",
      "!ui/node_modules/**/*",
      "!ui/public/**/*",
      "!ui/scripts/**/*",
      "!ui/src/**/*",
      "!Documentation/**/*",
      "!tickets/**/*",
      "!**/*.test.js",
      "!**/AGENTS.md",
      "!**/documentation.md",
      "!**/start.stderr.log",
      "!**/start.stdout.log"
    ],
    "mac": {
      "artifactName": "CouRM-${version}.${ext}",
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "linux": {
      "artifactName": "CouRM-${version}.${ext}",
      "category": "Office",
      "target": [
        "AppImage"
      ]
    },
    "win": {
      "artifactName": "CouRM-Setup-${version}.${ext}",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "deleteAppDataOnUninstall": false,
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true,
      "shortcutName": "CouRM"
    }
  }
}
